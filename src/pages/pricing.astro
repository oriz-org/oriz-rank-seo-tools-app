---
/*
 * /pricing — redirect to oriz.in/pricing.
 *
 * Per the Razorpay single-domain rule (knowledge/decisions/architecture/
 * billing-webhook-cf-pages-function.md + user mandate 2026-06-22), all
 * checkout flows live on oriz.in/pricing. This app's /pricing route
 * preserves discoverability but bounces visitors to the canonical
 * pricing surface.
 *
 * In dev (no oriz.in running), we render a brief notice with a link
 * back to the local hub instead of bouncing into a black hole.
 */
const fromSlug = 'rank-seo-tools'
const targetUrl = `https://oriz.in/pricing?from=${fromSlug}`

if (import.meta.env.PROD) {
  return Astro.redirect(targetUrl, 302)
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pricing — redirected to oriz.in</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${targetUrl}`} />
  </head>
  <body style="font-family: system-ui, sans-serif; max-width: 40rem; margin: 4rem auto; padding: 0 1.5rem; line-height: 1.6;">
    <h1>Pricing lives on oriz.in</h1>
    <p>All subscriptions across the Oriz family are managed at <a href={targetUrl}>{targetUrl}</a>.</p>
    <p>If you aren't redirected automatically, click the link above.</p>
  </body>
</html>
