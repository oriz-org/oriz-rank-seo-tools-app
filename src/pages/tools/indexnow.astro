---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="IndexNow ping — Oriz SEO" description="Generate IndexNow key file and ping URLs. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">IndexNow ping</h1>
    <p class="status mono ready">ready · v1</p>
    <p class="lede">Generate an IndexNow key, the key-file contents, and a one-click submit URL. Submission opens in a new tab; everything else runs in your browser.</p>

    <div class="app">
      <label class="lbl">Host (no protocol)
        <input id="host" class="io" type="text" placeholder="example.com" />
      </label>
      <label class="lbl">URLs (one per line)
        <textarea id="urls" class="io" rows="6" placeholder="https://example.com/page-1\nhttps://example.com/page-2"></textarea>
      </label>
      <div class="row">
        <button id="genkey" class="btn">Generate key</button>
        <button id="submit" class="btn primary">Submit to IndexNow</button>
      </div>
      <div id="out" class="out hidden"></div>
      <div id="err" class="err hidden"></div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin-bottom: 2rem; }
  .app { display: flex; flex-direction: column; gap: 1rem; }
  .lbl { display: flex; flex-direction: column; gap: 0.4rem; font-size: 12px; color: var(--muted); font-family: var(--font-mono); }
  .io { width: 100%; padding: 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; resize: vertical; }
  .row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.6rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); cursor: pointer; font-family: var(--font-mono); font-size: 12px; }
  .btn:hover { border-color: var(--ink); }
  .btn.primary { background: var(--accent); color: var(--paper); border-color: var(--accent); }
  .out { background: var(--paper-2); border: 1px solid var(--rule); padding: 1rem; font-family: var(--font-mono); font-size: 0.8rem; white-space: pre-wrap; word-break: break-all; }
  .err { color: var(--accent); font-family: var(--font-mono); font-size: 12px; }
  .hidden { display: none; }
</style>

<script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const host = $('host'), urls = $('urls'), out = $('out'), err = $('err');
    const show = (el, t) => { el.textContent = t; el.classList.remove('hidden'); };
    const hide = (el) => el.classList.add('hidden');
    function newKey() {
      const b = new Uint8Array(16);
      crypto.getRandomValues(b);
      return Array.from(b, (x) => x.toString(16).padStart(2, '0')).join('');
    }
    $('genkey').addEventListener('click', () => {
      hide(err);
      const h = host.value.trim().replace(/^https?:\/\//, '').replace(/\/$/, '');
      if (!h) return show(err, 'Enter a host first.');
      const k = newKey();
      show(out, `key: ${k}\nkey-file: https://${h}/${k}.txt\nfile contents (one line):\n${k}\n\nSave the file contents at the URL above before submitting.`);
    });
    $('submit').addEventListener('click', () => {
      hide(err);
      const h = host.value.trim().replace(/^https?:\/\//, '').replace(/\/$/, '');
      const list = urls.value.split(/\r?\n/).map((s) => s.trim()).filter(Boolean);
      if (!h) return show(err, 'Enter a host first.');
      if (list.length === 0) return show(err, 'Add at least one URL.');
      const m = out.textContent.match(/^key: ([a-f0-9]+)/);
      if (!m) return show(err, 'Generate a key first, save the key-file, then submit.');
      const key = m[1];
      const payload = { host: h, key, keyLocation: `https://${h}/${key}.txt`, urlList: list };
      const url = `https://api.indexnow.org/IndexNow?` + new URLSearchParams({ url: list[0], key });
      show(out, out.textContent + `\n\nPOST payload:\n${JSON.stringify(payload, null, 2)}\n\nOpening single-URL GET ping in a new tab…`);
      window.open(url, '_blank', 'noopener');
    });
  })();
</script>
