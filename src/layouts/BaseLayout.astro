---
import '~/styles/global.css'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz SEO — Diagnostics for the open web.', description = 'Keyword density, SERP preview, meta tag check, OG debugger, schema validator, sitemap, robots.txt, IndexNow, TF-IDF.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://seo.oriz.in').toString()
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">SEO</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href="/pricing/">pricing</a>
        <a href="https://auth.oriz.in/sign-in">sign in</a>
      </nav>
    </header>
    <div class="oriz-shell">
      <FamilySidebar slug="oriz-rank-seo-tools-app" title="SEO Tools">
        <a slot="tools" href="/tools/density/">Keyword density</a>
        <a slot="tools" href="/tools/indexnow/">IndexNow ping</a>
        <a slot="tools" href="/tools/meta-check/">Meta tag check</a>
        <a slot="tools" href="/tools/og-debug/">OG debugger</a>
        <a slot="tools" href="/tools/psi/">PageSpeed insights</a>
        <a slot="tools" href="/tools/robots/">robots.txt tester</a>
        <a slot="tools" href="/tools/schema/">Schema validator</a>
        <a slot="tools" href="/tools/serp/">SERP preview</a>
        <a slot="tools" href="/tools/sitemap/">Sitemap inspector</a>
        <a slot="tools" href="/tools/tfidf/">TF-IDF analysis</a>
      </FamilySidebar>
      <main id="main" class="oriz-main"><slot /></main>
    </div>
    <footer class="site">
      <span>Oriz SEO · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>
