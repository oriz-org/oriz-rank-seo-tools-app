---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Schema.org validator — Oriz SEO" description="Validate JSON-LD structured data in your browser. Checks syntax, required fields, and common Schema.org types.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Schema.org validator</h1>
    <p class="status mono ready">ready · v1</p>
    <p class="lede">Paste a JSON-LD block (or full HTML — we extract every <code>&lt;script type="application/ld+json"&gt;</code>). We check JSON syntax, required Schema.org fields, and common pitfalls. Runs in your browser.</p>

    <div class="app">
      <label class="lbl">JSON-LD or HTML
        <textarea id="src" class="io" rows="12" placeholder='{&#10;  "@context": "https://schema.org",&#10;  "@type": "Article",&#10;  "headline": "..."&#10;}'></textarea>
      </label>
      <div class="row">
        <button id="check" class="btn primary">Validate</button>
      </div>
      <div id="out" class="out hidden"></div>
      <div id="err" class="err hidden"></div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 60ch; margin-bottom: 2rem; }
  .app { display: flex; flex-direction: column; gap: 1rem; }
  .lbl { display: flex; flex-direction: column; gap: 0.4rem; font-size: 12px; color: var(--muted); font-family: var(--font-mono); }
  .io { width: 100%; padding: 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; resize: vertical; }
  .row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.6rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); cursor: pointer; font-family: var(--font-mono); font-size: 12px; }
  .btn:hover { border-color: var(--ink); }
  .btn.primary { background: var(--accent); color: var(--paper); border-color: var(--accent); }
  .out { background: var(--paper-2); border: 1px solid var(--rule); padding: 1rem; font-family: var(--font-mono); font-size: 0.8rem; white-space: pre-wrap; }
  .err { color: var(--accent); font-family: var(--font-mono); font-size: 12px; }
  .hidden { display: none; }
  .ok { color: var(--accent); }
  .warn { color: #b08800; }
  .bad { color: var(--accent); font-weight: 600; }
</style>

<script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const out = $('out'), err = $('err');
    const show = (el, t) => { el.innerHTML = t; el.classList.remove('hidden'); };
    const hide = (el) => el.classList.add('hidden');

    const required = {
      Article: ['headline', 'author', 'datePublished'],
      NewsArticle: ['headline', 'author', 'datePublished'],
      BlogPosting: ['headline', 'author', 'datePublished'],
      Product: ['name'],
      Recipe: ['name', 'recipeIngredient', 'recipeInstructions'],
      Event: ['name', 'startDate', 'location'],
      Organization: ['name'],
      Person: ['name'],
      WebSite: ['name', 'url'],
      BreadcrumbList: ['itemListElement'],
      FAQPage: ['mainEntity'],
      VideoObject: ['name', 'description', 'thumbnailUrl', 'uploadDate'],
      LocalBusiness: ['name', 'address'],
      Review: ['itemReviewed', 'reviewRating', 'author'],
    };

    function extract(src) {
      const blocks = [];
      const rx = /<script[^>]*type=["']application\/ld\+json["'][^>]*>([\s\S]*?)<\/script>/gi;
      let m;
      while ((m = rx.exec(src)) !== null) blocks.push(m[1]);
      if (blocks.length === 0) blocks.push(src);
      return blocks;
    }

    function esc(s) { return String(s).replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c])); }

    function validate(obj, idx) {
      const lines = [];
      const items = Array.isArray(obj) ? obj : [obj];
      items.forEach((it, i) => {
        const label = items.length > 1 ? `block ${idx + 1}.${i + 1}` : `block ${idx + 1}`;
        if (!it || typeof it !== 'object') { lines.push(`<span class="bad">${label}: not an object</span>`); return; }
        const ctx = it['@context'];
        if (!ctx) lines.push(`<span class="warn">${label}: missing @context</span>`);
        else if (!/schema\.org/i.test(String(ctx))) lines.push(`<span class="warn">${label}: @context is not schema.org</span>`);
        const type = it['@type'];
        if (!type) { lines.push(`<span class="bad">${label}: missing @type</span>`); return; }
        lines.push(`<span class="ok">${label}: @type = ${esc(type)}</span>`);
        const typeName = Array.isArray(type) ? type[0] : type;
        const req = required[typeName];
        if (req) {
          for (const f of req) {
            if (it[f] === undefined || it[f] === null || it[f] === '') {
              lines.push(`  <span class="bad">missing required: ${f}</span>`);
            } else {
              lines.push(`  <span class="ok">has ${f}</span>`);
            }
          }
        } else {
          lines.push(`  <span class="warn">no required-field schema for ${esc(typeName)} (manual check)</span>`);
        }
      });
      return lines.join('\n');
    }

    $('check').addEventListener('click', () => {
      hide(err);
      const src = $('src').value.trim();
      if (!src) { err.textContent = 'Paste some JSON-LD or HTML first.'; err.classList.remove('hidden'); hide(out); return; }
      const blocks = extract(src);
      const parts = [];
      blocks.forEach((b, i) => {
        try {
          const obj = JSON.parse(b.trim());
          parts.push(validate(obj, i));
        } catch (e) {
          parts.push(`<span class="bad">block ${i + 1}: JSON parse error — ${esc(e.message)}</span>`);
        }
      });
      show(out, parts.join('\n\n'));
    });
  })();
</script>
