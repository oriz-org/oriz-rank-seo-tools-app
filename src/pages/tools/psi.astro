---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="PageSpeed launcher — Oriz SEO" description="Open Google PageSpeed Insights for any URL in mobile or desktop. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">PageSpeed launcher</h1>
    <p class="status mono ready">ready · v1</p>
    <p class="lede">Open Google's PageSpeed Insights for any URL with mobile/desktop strategy preselected. The real Core Web Vitals run on Google's infra — this just builds the link, in your browser.</p>

    <div class="app">
      <label class="lbl">URL
        <input id="url" class="io" type="url" placeholder="https://example.com/page" />
      </label>
      <fieldset class="lbl">Strategy
        <div class="row">
          <label class="radio"><input type="radio" name="s" value="mobile" checked /> mobile</label>
          <label class="radio"><input type="radio" name="s" value="desktop" /> desktop</label>
          <label class="radio"><input type="radio" name="s" value="both" /> both</label>
        </div>
      </fieldset>
      <div class="row">
        <button id="go" class="btn primary">Open PageSpeed</button>
        <button id="copy" class="btn">Copy URL</button>
      </div>
      <div id="out" class="out hidden"></div>
      <div id="err" class="err hidden"></div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin-bottom: 2rem; }
  .app { display: flex; flex-direction: column; gap: 1rem; }
  .lbl { display: flex; flex-direction: column; gap: 0.4rem; font-size: 12px; color: var(--muted); font-family: var(--font-mono); border: none; padding: 0; }
  .io { width: 100%; padding: 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; }
  .row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .radio { font-family: var(--font-mono); font-size: 12px; color: var(--ink); display: inline-flex; gap: 0.4rem; align-items: center; }
  .btn { padding: 0.6rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); cursor: pointer; font-family: var(--font-mono); font-size: 12px; }
  .btn:hover { border-color: var(--ink); }
  .btn.primary { background: var(--accent); color: var(--paper); border-color: var(--accent); }
  .out { background: var(--paper-2); border: 1px solid var(--rule); padding: 1rem; font-family: var(--font-mono); font-size: 0.8rem; white-space: pre-wrap; word-break: break-all; }
  .err { color: var(--accent); font-family: var(--font-mono); font-size: 12px; }
  .hidden { display: none; }
</style>

<script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const out = $('out'), err = $('err');
    const show = (el, t) => { el.textContent = t; el.classList.remove('hidden'); };
    const hide = (el) => el.classList.add('hidden');
    function strat() { return document.querySelector('input[name="s"]:checked').value; }
    function urls() {
      const u = $('url').value.trim();
      if (!u) throw new Error('Enter a URL first.');
      try { new URL(u); } catch { throw new Error('Not a valid URL.'); }
      const base = 'https://pagespeed.web.dev/analysis?url=' + encodeURIComponent(u);
      const s = strat();
      if (s === 'both') return [base + '&form_factor=mobile', base + '&form_factor=desktop'];
      return [base + '&form_factor=' + s];
    }
    $('go').addEventListener('click', () => {
      hide(err);
      try {
        const list = urls();
        list.forEach((u) => window.open(u, '_blank', 'noopener'));
        show(out, 'Opened:\n' + list.join('\n'));
      } catch (e) { show(err, e.message); }
    });
    $('copy').addEventListener('click', async () => {
      hide(err);
      try {
        const list = urls();
        await navigator.clipboard.writeText(list.join('\n'));
        show(out, 'Copied to clipboard:\n' + list.join('\n'));
      } catch (e) { show(err, e.message); }
    });
  })();
</script>
